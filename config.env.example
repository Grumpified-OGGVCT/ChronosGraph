# ChronosGraph Configuration
GEMINI_API_KEY=your-key-here
MODEL_VERSION=gemini-2.5-pro
MAX_CHUNK_SIZE_MINUTES=15

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chronosgraph

# Storage Paths
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/db/queue.db
VIDEO_CACHE_DIR=./data/cache/video
AUDIO_CACHE_DIR=./data/cache/audio
LOG_DIR=./logs
